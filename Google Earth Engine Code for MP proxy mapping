//////////////////////////////////////////////////////
// Chart: MP Time Series (Winter)                   //
//////////////////////////////////////////////////////

var MPseries = winterProcessed.map(function(img) {
  var meanMP = img.reduceRegion({
    reducer: ee.Reducer.mean(),
    geometry: blacksburg,
    scale: 10,
    maxPixels: 1e8
  });
  var date = img.get('system:time_start');
  return ee.Feature(null, {
    'date': ee.Date(date).format('YYYY-MM-dd'),
    'MP1': meanMP.get('MP1')
  });
});

