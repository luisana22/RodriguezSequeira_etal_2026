var S2 = ee.ImageCollection("COPERNICUS/S2_SR_HARMONIZED"),
    Points = ee.FeatureCollection("projects/ee-lrs/assets/LRS_locations"),
    blacksburg = /* color: #d63000 */ee.Geometry.Point([-80.56464169311523, 37.198021365160315]);

//////////////////////////////////////////////////////
// Parameters and AOI                               //
//////////////////////////////////////////////////////

var date_start = '2023-09-05';
var date_end = '2024-09-29';

var winter_start = '2023-12-01';
var winter_end = '2024-03-01';


var AOI = Points.geometry().bounds();

//////////////////////////////////////////////////////
// Sentinel-2 Filtering + Masking                   //
//////////////////////////////////////////////////////

var S2_filtered = S2
  .filterDate(date_start, date_end)
  .filterBounds(AOI)
  .filterMetadata('CLOUDY_PIXEL_PERCENTAGE', 'less_than', 70);

function cloudWaterMask(img) {
  var scl = img.select('SCL');
  var mask = scl.eq(6).or(scl.eq(4)).or(scl.eq(5)).or(scl.eq(2));
  return img.updateMask(mask);
}

var sentinel = S2_filtered.map(cloudWaterMask);

//////////////////////////////////////////////////////
// Indices: NDWI, NDTI, MP1, Turbidity, Water Mask //
//////////////////////////////////////////////////////

// Functions
function addIndices(img) {
  var ndwi = img.normalizedDifference(['B3', 'B8']).rename('NDWI');
  var ndti = img.normalizedDifference(['B4', 'B3']).rename('NDTI');
  return img.addBands(ndwi).addBands(ndti);
}

//thesis version with 2/14: 10 ** (1.896 + 2.0897 * ndti)
//without 2/14 and ouliers: 〖log〗_10 (MP/L) = 1.835 + 1.969 *NDTI                                           (eq.4)

function addMP1(img) {
  var mp1 = img.expression('10 ** (1.835 + 1.969 * ndti)', {
    ndti: img.select('NDTI')
  }).rename('MP1');
  return img.addBands(mp1);
}

function addTurbidity(img) {
  var turb = img.expression('16.183 + 55.729 * ndti', {
    ndti: img.select('NDTI')
  }).rename('Turbidity');
  return img.addBands(turb);
}

function clipToWater(img) {
  var waterMask = img.select('NDWI').gt(0);
  var mpWater = img.select('MP1').updateMask(waterMask).rename('MP_water1');
  var turbWater = img.select('Turbidity').updateMask(waterMask).rename('Turbidity_water');
  return img.addBands(mpWater).addBands(turbWater);
}

// Apply all functions to Sentinel-2 collection
var processed = sentinel
  .map(addIndices)
  .map(addMP1)
  .map(addTurbidity)
  .map(clipToWater);

//////////////////////////////////////////////////////
// Seasonal Filter: Winter Only                     //
//////////////////////////////////////////////////////

var winterProcessed = processed.filterDate(winter_start, winter_end);

//////////////////////////////////////////////////////
// Visualization Parameters                         //
//////////////////////////////////////////////////////

var MPviz = {
  min: 40,
  max: 150,
  palette: ['4112ff', '0affff', '10ff17', 'fbff00', 'ffa604', 'ff0000']
};

var turbViz = {
  min: 0,
  max: 30,
  palette: ['00ffff', '00ff00', 'ffff00', 'ff9900', 'ff0000']
};

var trueColorVis = {
  bands: ['B4', 'B3', 'B2'],
  min: 0,
  max: 3000,
  gamma: 1.2
};

//////////////////////////////////////////////////////
// Map Initialization & First Image Layers          //
//////////////////////////////////////////////////////

Map.setCenter(-80.5655, 37.198, 17);
var firstImg = winterProcessed.first();

Map.addLayer(firstImg, trueColorVis, 'True Color - Mapping Day');
Map.addLayer(firstImg.select('MP_water1'), MPviz, 'MP over Water (log10)');
Map.addLayer(firstImg.select('Turbidity_water'), turbViz, 'Turbidity over Water');

Map.addLayer(firstImg.select(['B4', 'B3', 'B2']), trueColorVis, 'True Color - Mapping Day');
Map.addLayer(firstImg.select('MP_water1'), MPviz, 'MP Water - ');

