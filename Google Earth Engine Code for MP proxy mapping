// UI Slider for MP over Water                      //
//////////////////////////////////////////////////////
// =======================
// UI Slider for MP + RGB
// =======================

// Get image list & dates
var imageList = winterProcessed.toList(winterProcessed.size());
var dates = imageList.map(function(img) {
  return ee.Date(ee.Image(img).get('system:time_start')).format('YYYY-MM-dd');
}).getInfo();

// Create a label to show the selected date
var label = ui.Label('Date: ' + dates[0]);

// Create the slider
var slider = ui.Slider({
  min: 0,
  max: dates.length - 1,
  step: 1,
  value: 0,
  style: {stretch: 'horizontal'},
  onChange: function(index) {
    var img = ee.Image(imageList.get(index));
    var date = dates[index];

    var mpLayer = img.select('MP_water1');
    var trueColorLayer = img.select(['B4', 'B3', 'B2']);

    // Remove previous MP and true color layers
    Map.layers().forEach(function(layer) {
      var name = layer.getName();
      name = (name !== null && name !== undefined) ? String(name) : '';
      if (name.indexOf('MP Water -') === 0 || name === 'True Color - Mapping Day') {
        Map.remove(layer);
      }
    });

    // Add new layers for current date
    Map.addLayer(trueColorLayer, trueColorVis, 'True Color - Mapping Day');
    Map.addLayer(mpLayer, MPviz, 'MP Water - ' + date);

    label.setValue('Date: ' + date);
  }
});

// Initialize with the first image's layers
var firstImg = ee.Image(imageList.get(0));
Map.addLayer(firstImg.select(['B4', 'B3', 'B2']), trueColorVis, 'True Color - Mapping Day');
Map.addLayer(firstImg.select('MP_water1'), MPviz, 'MP Water - ' + dates[0]);

// UI panel
var panel = ui.Panel({
  widgets: [
    ui.Label('MP + True Color (Slider)', {fontWeight: 'bold', fontSize: '16px'}),
    label,
    slider
  ],
  style: {
    width: '300px',
    position: 'top-right'
  }
});

Map.add(panel);

